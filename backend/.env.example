# Required API keys
GEMINI_API_KEY=your-gemini-api-key-here
VOYAGE_API_KEY=your-voyage-api-key-here

# Search API Key (optional — falls back to DuckDuckGo if missing)
SERPER_API_KEY=your-serper-api-key-here

# Database
DATABASE_URL=postgresql+psycopg://smart_briefing:smart_briefing@localhost:5432/smart_briefing

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Model configuration
CREW_LLM=gemini/gemini-2.5-flash
POLISH_MODEL=gemini-2.5-flash
CHAT_MODEL=gemini-2.5-flash

# Voyage RAG configuration
VOYAGE_EMBEDDING_MODEL=voyage-4
VOYAGE_EMBEDDING_DIMENSION=1024
RAG_TOP_K=6
RAG_CHUNK_SIZE=1800
RAG_CHUNK_OVERLAP=240

# Session cookies
SESSION_COOKIE_NAME=smart_briefing_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_EXPIRE_DAYS=30

# Concurrency — max parallel crew runs
MAX_CREW_WORKERS=4

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
