# Required API keys
GEMINI_API_KEY=your_gemini_api_key
VOYAGE_API_KEY=your_voyage_api_key

# Search API key (optional — falls back to DuckDuckGo if missing)
SERPER_API_KEY=your_serper_api_key_optional

# Database
DATABASE_URL=postgresql+psycopg://smart_briefing:smart_briefing@localhost:5432/smart_briefing

# CORS and request security
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_PROXY_IPS=
RATE_LIMIT_MAX_KEYS=10000
REDIS_URL=

# Model configuration
CREW_LLM=gemini/gemini-2.5-flash
POLISH_MODEL=gemini-3.5-flash
CHAT_MODEL=gemini-3.5-flash

# Voyage RAG configuration
VOYAGE_EMBEDDING_MODEL=voyage-4
VOYAGE_EMBEDDING_DIMENSION=1024
RAG_TOP_K=6
RAG_CHUNK_SIZE=1800
RAG_CHUNK_OVERLAP=240

# Session cookies
SESSION_COOKIE_NAME=smart_briefing_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_EXPIRE_DAYS=30

# Object storage for profile photos
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000
OBJECT_STORAGE_BUCKET=profile-photos
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1
PROFILE_UPLOAD_MAX_BYTES=5242880

# Stripe Test Mode billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price
BILLING_SUCCESS_URL=http://localhost:3000/settings/billing?checkout=success
BILLING_CANCEL_URL=http://localhost:3000/settings/billing?checkout=cancelled

# Concurrency — max parallel crew runs
MAX_CREW_WORKERS=4

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
